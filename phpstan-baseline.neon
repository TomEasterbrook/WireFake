parameters:
    ignoreErrors:
        -
            message: "#Called 'env' outside of the config directory#"
            path: config/fakeable.php
        -
            message: "#Trait TomEasterbrook\\\\LivewireFakeable\\\\Concerns\\\\HasFakeable is used zero times and is not analysed#"
            path: src/Concerns/HasFakeable.php
        -
            message: "#Call to an undefined method Faker\\\\Generator::state\\(\\)#"
            path: src/Services/FakeableResolver.php
