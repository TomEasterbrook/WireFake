{
    "name": "tomeasterbrook/livewire-fakeable",
    "description": "Fill your Livewire component state with realistic fake data during local development.",
    "keywords": [
        "laravel",
        "livewire",
        "faker",
        "livewire-fakeable",
        "fakeable"
    ],
    "homepage": "https://github.com/TomEasterbrook/livewire-fakeable",
    "license": "MIT",
    "authors": [
        {
            "name": "Tom Easterbrook",
            "email": "tomeasterbrook98@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "livewire/livewire": "^4.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^11.1.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "spatie/laravel-ray": "^1.35"
    },
    "autoload": {
        "psr-4": {
            "TomEasterbrook\\LivewireFakeable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TomEasterbrook\\LivewireFakeable\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TomEasterbrook\\LivewireFakeable\\Providers\\LivewireFakeableServiceProvider"
            ],
            "aliases": {
                "LivewireFakeable": "TomEasterbrook\\LivewireFakeable\\Facades\\LivewireFakeable"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
